# Copiar a .env y completar con valores reales. NO commitear el .env real.

# --- Mongo (contenedor mongo) ---
# Usuario/clave root de administración del propio Mongo.
MONGO_INITDB_ROOT_USERNAME=root
MONGO_INITDB_ROOT_PASSWORD=changeme

# Base de datos de la aplicación.
MONGO_INITDB_DATABASE=kuntur

# Usuario de aplicación creado por database/init/01_init.js, con permisos
# readWrite solo sobre MONGO_INITDB_DATABASE. El back se conecta con estas
# credenciales (no con las de root).
MONGO_APP_USER=kuntur_user
MONGO_APP_PASSWORD=changeme

# --- Back (contenedor back) ---
# Token requerido para los endpoints admin (ver app.auth.require_admin).
ADMIN_TOKEN=changeme

# --- Cloudflared (contenedor cloudflared) ---
# Token del túnel, generado en el dashboard de Cloudflare Zero Trust.
TUNNEL_TOKEN=changeme
